[all:vars]

# Ansible
ansible_connection=local

# Common variables
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#general-variables
# -----------------------------------------------------
postgresql_admin_username=postgres
postgresql_admin_password=<set your own>
registry_username=<your RHN username>
registry_password=<your RHN password>
redis_mode=standalone

# AAP Gateway
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#platform-gateway-variables
# -----------------------------------------------------
gateway_admin_password=<set your own>
gateway_pg_host=aap.example.org
gateway_pg_password=<set your own>

# AAP Controller
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#controller-variables
# -----------------------------------------------------
controller_admin_password=<set your own>
controller_pg_host=aap.example.org
controller_pg_password=<set your own>
controller_percent_memory_capacity=0.5

# AAP Automation Hub
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#hub-variables
# -----------------------------------------------------
hub_admin_password=<set your own>
hub_pg_host=aap.example.org
hub_pg_password=<set your own>
hub_seed_collections=false

# AAP EDA Controller
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#event-driven-ansible-variables
# -----------------------------------------------------
eda_admin_password=<set your own>
eda_pg_host=aap.example.org
eda_pg_password=<set your own>

# Automation Metrics Service
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.7/html/containerized_installation/appendix-inventory-files-vars#automation-metrics-service-variables
# -----------------------------------------------------
automationmetrics_pg_host=aap.example.org
automationmetrics_pg_password=<set your own>
automationmetrics_controller_read_pg_host=aap.example.org
automationmetrics_controller_read_pg_password=<set your own>

# Optional variables — uncomment and customize as needed
# Complex list/dictionary variables are documented here; see vars-example.yml
# and pass with: ansible-playbook ... -e @vars.yml
# -----------------------------------------------------

# Common / installer-wide
# -----------------------------------------------------
# bundle_dir=/path/to/bundle  # Directory containing offline bundle (images/ and collections/); required when bundle_install=true
# bundle_install=false  # Use offline/bundled installation instead of pulling from registry
# ca_tls_cert=/path/to/ca.crt  # Path to custom TLS CA certificate used to sign component certificates
# ca_tls_key=/path/to/ca.key  # Path to custom TLS CA private key
# ca_tls_key_passphrase=<set your own>  # Passphrase for the TLS CA private key, if encrypted
# ca_tls_remote=false  # TLS CA cert/key files live on remote hosts (not the Ansible control node)
# client_request_timeout=30  # End-user HTTP request timeout in seconds (minimum 10); drives nginx/uwsgi/gunicorn timeouts
# container_compress=gzip  # Compression algorithm for container layers (e.g. gzip)
# container_keep_images=false  # Keep container images on hosts during uninstall
# container_pull_images=true  # Pull newer container images from registry during install/upgrade
# custom_ca_cert=/path/to/custom-ca.crt  # Org CA PEM added to the AAP platform trust bundle for outbound TLS to external services (CyberArk, corporate DBs, APIs); required for *_pg_cert_auth with verify-ca/verify-full; not automatic in Execution Environments
# feature_flags=  # Dictionary of feature flags (keys must start with feature_, values boolean); see vars-example.yml
# images_tmp_dir=/tmp  # Directory to extract bundled container images during offline install
# registry_auth=true  # Authenticate to the container registry (disable for open registries)
# registry_ns_aap=ansible-automation-platform-27  # Registry namespace for AAP component images
# registry_ns_aap_tp=ansible-automation-platform-tech-preview  # Registry namespace for AAP tech-preview images
# registry_ns_rhel=rhel9  # Registry namespace for RHEL base images
# registry_tls_verify=true  # Verify TLS when connecting to the container registry
# registry_url=registry.redhat.io  # Container registry URL
# use_archive_compression=true  # Compress backup archive files globally (overridden per-component vars exist)
# use_db_compression=false  # Compress database dumps globally during backup

# Host tuning
# -----------------------------------------------------
# tune_host_limits=true  # Apply kernel sysctl, ulimit, and podman PID tuning on service hosts during install
# host_tuning_sysctl_fs_inotify_max_user_instances=8192  # sysctl fs.inotify.max_user_instances written to /etc/sysctl.d/99-aap.conf
# host_tuning_sysctl_fs_inotify_max_user_watches=524288  # sysctl fs.inotify.max_user_watches written to /etc/sysctl.d/99-aap.conf
# host_tuning_nofile_limit_soft=524288  # Soft nofile ulimit for the user running AAP containers
# host_tuning_nofile_limit_hard=524288  # Hard nofile ulimit for the user running AAP containers

